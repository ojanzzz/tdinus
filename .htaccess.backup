# Redirect semua request ke folder public jika document root tidak bisa di-set ke /public
# File ini harus di: ~/public_html/.htaccess (bukan public/.htaccess)
# Gunakan jika document root masih menunjuk ke root aplikasi

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Jika request bukan ke folder public
    RewriteCond %{REQUEST_URI} !^/public/
    
    # Dan bukan file atau folder yang ada
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Redirect ke public folder
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
