# php -- BEGIN cPanel-generated handler, do not edit
# Set the "ea-php74" package as the default "PHP" programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php74___lsphp .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # For requests to actual files or directories, skip
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # If the request is not to /tdinus.com/public, rewrite to /tdinus.com/public
    RewriteCond %{REQUEST_URI} !^/tdinus.com/public/
    RewriteRule ^(.*)$ /tdinus.com/public/$1 [L,QSA]

    # For requests to /tdinus.com/public, pass to index.php
    RewriteCond %{REQUEST_URI} ^/tdinus.com/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^tdinus.com/public/(.*)$ /tdinus.com/public/index.php [L,QSA]
</IfModule>

