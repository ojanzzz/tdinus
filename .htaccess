# php -- BEGIN cPanel-generated handler, do not edit
# Set the "ea-php74" package as the default "PHP" programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php74___lsphp .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# ============================================================
# Laravel & TDINUS Configuration
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # HTTPS Redirect (uncomment if needed)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Handle public folder routing
    # If the request is not for a real file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-l

    # If requesting /public, process normally
    RewriteCond %{REQUEST_URI} ^/public
    RewriteRule ^public/(.*)$ public/index.php?route=$1 [L,QSA]

    # Otherwise, redirect non-public requests
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/public
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# ============================================================
# Additional Security & Performance Headers
# ============================================================

<IfModule mod_headers.c>
    # Prevent access to sensitive files
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# ============================================================
# Block access to sensitive directories
# ============================================================

<FilesMatch "^\.env|^\.git|^storage|^bootstrap">
    Order allow,deny
    Deny from all
</FilesMatch>

# ============================================================
# END TDINUS Configuration
# ============================================================
